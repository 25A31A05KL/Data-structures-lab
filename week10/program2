#include <iostream>
#include <vector>
using namespace std;

int main() {
    int m, key, loc, nk;
    cout << "Enter size of hash table: ";
    cin >> m;

    vector<int> hash(m, -999);

    cout << "Enter number of key elements: ";
    cin >> nk;

    for (int i = 0; i < nk; i++) {
        cout << "Enter key value " << i + 1 << ": ";
        cin >> key;
        loc = key % m;

        // Linear probing
        int j = 0;
        while (hash[(loc + j) % m] != -999 && j < m) {
            j++;
        }

        if (j < m) {
            hash[(loc + j) % m] = key;
        } else {
            cout << "Hash table is full, cannot insert key: " << key << endl;
        }
    }

    cout << "Hash table status:\n";
    for (int i = 0; i < m; i++) {
        cout << hash[i] << " ";
    }
    cout << endl;

    return 0;
}
