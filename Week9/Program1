#include <iostream>
using namespace std;
#define MAX 10 
int main() {
    int arr[MAX];
    int front = -1, rear = -1;
    int choice, x;

    while (true) {
        cout << "\n--- DEQUE OPERATIONS ---\n";
        cout << "1. Insert Front\n";
        cout << "2. Insert Rear\n";
        cout << "3. Delete Front\n";
        cout << "4. Delete Rear\n";
        cout << "5. Display\n";
        cout << "6. Exit\n";
        cout << "Enter choice: ";
        cin >> choice;

        switch (choice) {

        case 1: // Insert Front
            if ((front == 0 && rear == MAX - 1) || (front == rear + 1)) {
                cout << "Deque is Full\n";
            } else {
                cout << "Enter element: ";
                cin >> x;

                if (front == -1) {
                    front = rear = 0;
                } else if (front == 0) {
                    front = MAX - 1;
                } else {
                    front--;
                }
                arr[front] = x;
            }
            break;

        case 2: // Insert Rear
            if ((front == 0 && rear == MAX - 1) || (front == rear + 1)) {
                cout << "Deque is Full\n";
            } else {
                cout << "Enter element: ";
                cin >> x;

                if (front == -1) {
                    front = rear = 0;
                } else if (rear == MAX - 1) {
                    rear = 0;
                } else {
                    rear++;
                }
                arr[rear] = x;
            }
            break;

        case 3: // Delete Front
            if (front == -1) {
                cout << "Deque is Empty\n";
            } else {
                cout << "Deleted element: " << arr[front] << endl;

                if (front == rear) {
                    front = rear = -1;
                } else if (front == MAX - 1) {
                    front = 0;
                } else {
                    front++;
                }
            }
            break;

        case 4: // Delete Rear
            if (front == -1) {
                cout << "Deque is Empty\n";
            } else {
                cout << "Deleted element: " << arr[rear] << endl;

                if (front == rear) {
                    front = rear = -1;
                } else if (rear == 0) {
                    rear = MAX - 1;
                } else {
                    rear--;
                }
            }
            break;

        case 5: // Display
            if (front == -1) {
                cout << "Deque is Empty\n";
            } else {
                cout << "Deque elements: ";
                int i = front;
                while (true) {
                    cout << arr[i] << " ";
                    if (i == rear)
                        break;
                    i = (i + 1) % MAX;
                }
                cout << endl;
            }
            break;

        case 6:
            return 0;

        default:
            cout << "Invalid choice\n";
        }
    }
}
