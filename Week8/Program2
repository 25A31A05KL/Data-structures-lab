#include <iostream>
using namespace std;

class node
{
public:
    int data;
    node *link;
};

int main()
{
    node *f = NULL, *r = NULL, *cn, *t;
    int ch;

    do
    {
        cout << "\n1.Enqueue\n2.Dequeue\n3.Peek\n4.Display\n5.Exit";
        cout << "\nEnter your choice: ";
        cin >> ch;

        switch(ch)
        {
            case 1: // Enqueue
                cn = new node;
                cout << "Enter item: ";
                cin >> cn->data;
                cn->link = NULL;

                if(f == NULL)
                {
                    f = r = cn;
                }
                else
                {
                    r->link = cn;
                    r = cn;
                }
                cout<< cn->data <<" is Inserted into queue";
                break;

            case 2: // Dequeue
                if(f == NULL)
                {
                    cout << "\nQueue Underflow";
                }
                else
                {
                    t = f;
                    cout << "\nDeleted item: " << t->data;
                    f = f->link;
                    delete t;

                    if(f == NULL)
                        r = NULL;
                }
                break;

            case 3: // Peek
                if(f == NULL)
                    cout << "\nQueue is empty";
                else
                    cout << "\nFront element: " << f->data;
                break;

            case 4: // Display
                if(f == NULL)
                {
                    cout << "\nQueue is empty";
                }
                else
                {
                    t = f;
                    cout << "\nQueue elements: ";
                    while(t != NULL)
                    {
                        cout << t->data << " ";
                        t = t->link;
                    }
                }
                break;

            case 5:
                cout << "\nExiting...";
                break;

            default:
                cout << "\nInvalid choice";
        }
        cout<<"\n ENTER 1 TO CONTINUE 0 TO EXIT";
        cin>>ch;

    } while(ch);

    return 0;
}
